FWD_START_TEST([add source with mac address])
AT_KEYWORDS(gh703)

FWD_CHECK([--zone=home --add-source=34:7e:5c:3a:4c:32], 0, [ignore])

NFT_LIST_RULES([inet], [nat_POSTROUTING_dispatch], 0, [dnl
    table inet firewalld {
        chain nat_POSTROUTING_dispatch {
            ether saddr 34:7e:5c:3a:4c:32 jump nat_POST_home_dispatch_stage2
            jump nat_POST_public_dispatch_stage2
        }
    }
])
NFT_LIST_RULES([inet], [nat_POST_home_dispatch_stage2], 0, [dnl
    table inet firewalld {
        chain nat_POST_home_dispatch_stage2 {
            ether daddr 34:7e:5c:3a:4c:32 jump nat_POST_home_to_home
            jump nat_POST_home_to_public
        }
    }
])

dnl NOTE: iptables does _not_ support matching mac destination.

FWD_END_TEST
