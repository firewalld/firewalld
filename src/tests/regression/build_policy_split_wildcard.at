FWD_START_TEST([build policy split wildcards])
AT_KEYWORDS(gh892 policy)

dnl Setting up policy and adding interfaces that will remain for the duration of
dnl the tests
dnl
FWD_CHECK([--permanent --new-policy=foobar], 0, [ignore])
FWD_CHECK([--permanent --policy foobar --add-ingress-zone internal], 0, [ignore])
FWD_CHECK([--permanent --policy foobar --add-egress-zone public], 0, [ignore])
FWD_CHECK([--permanent --zone internal --add-interface foobar0], 0, [ignore])
FWD_CHECK([--permanent --zone internal --add-interface foobar1], 0, [ignore])
FWD_CHECK([--permanent --zone public --add-interface foobar2], 0, [ignore])
FWD_CHECK([--permanent --zone public --add-interface foobar3], 0, [ignore])
FWD_RELOAD

dnl Checking when the internal zone (iifname) is the only one with a wildcard
dnl
FWD_CHECK([--zone internal --add-interface tun+], 0, [ignore])
NFT_LIST_RULES([inet], [filter_FORWARD_dispatch], 0, [dnl
    table inet firewalld {
        chain filter_FORWARD_dispatch {
            iifname "foobar0" jump filter_FWD_internal_dispatch_stage2
            iifname "foobar1" jump filter_FWD_internal_dispatch_stage2
            iifname "tun*" jump filter_FWD_internal_dispatch_stage2
            iifname "foobar2" jump filter_FWD_public_dispatch_stage2
            iifname "foobar3" jump filter_FWD_public_dispatch_stage2
            jump filter_FWD_public_dispatch_stage2
        }
    }
])
NFT_LIST_RULES([inet], [filter_FWD_internal_dispatch_stage2], 0, [dnl
    table inet firewalld {
        chain filter_FWD_internal_dispatch_stage2 {
            oifname "foobar0" jump filter_FWD_internal_to_internal
            oifname "foobar1" jump filter_FWD_internal_to_internal
            oifname "tun*" jump filter_FWD_internal_to_internal
            oifname "foobar2" jump filter_FWD_internal_to_public
            oifname "foobar3" jump filter_FWD_internal_to_public
            jump filter_FWD_internal_to_public
        }
    }
])
FWD_CHECK([--zone internal --remove-interface tun+], 0, [ignore])


dnl Checking when the public zone (oifname) is the only one with a wildcard
dnl
FWD_CHECK([--zone public --add-interface tun+], 0, [ignore])
NFT_LIST_RULES([inet], [filter_FORWARD_dispatch], 0, [dnl
    table inet firewalld {
        chain filter_FORWARD_dispatch {
            iifname "foobar0" jump filter_FWD_internal_dispatch_stage2
            iifname "foobar1" jump filter_FWD_internal_dispatch_stage2
            iifname "foobar2" jump filter_FWD_public_dispatch_stage2
            iifname "foobar3" jump filter_FWD_public_dispatch_stage2
            iifname "tun*" jump filter_FWD_public_dispatch_stage2
            jump filter_FWD_public_dispatch_stage2
        }
    }
])
NFT_LIST_RULES([inet], [filter_FWD_public_dispatch_stage2], 0, [dnl
    table inet firewalld {
        chain filter_FWD_public_dispatch_stage2 {
            oifname "foobar0" jump filter_FWD_public_to_internal
            oifname "foobar1" jump filter_FWD_public_to_internal
            oifname "foobar2" jump filter_FWD_public_to_public
            oifname "foobar3" jump filter_FWD_public_to_public
            oifname "tun*" jump filter_FWD_public_to_public
            jump filter_FWD_public_to_public
        }
    }
])

dnl Checking when they are both wildcards
dnl
FWD_CHECK([--zone internal --add-interface net+], 0, [ignore])
NFT_LIST_RULES([inet], [filter_FORWARD_dispatch], 0, [dnl
    table inet firewalld {
        chain filter_FORWARD_dispatch {
            iifname "foobar0" jump filter_FWD_internal_dispatch_stage2
            iifname "foobar1" jump filter_FWD_internal_dispatch_stage2
            iifname "net*" jump filter_FWD_internal_dispatch_stage2
            iifname "foobar2" jump filter_FWD_public_dispatch_stage2
            iifname "foobar3" jump filter_FWD_public_dispatch_stage2
            iifname "tun*" jump filter_FWD_public_dispatch_stage2
            jump filter_FWD_public_dispatch_stage2
        }
    }
])
NFT_LIST_RULES([inet], [filter_FWD_internal_dispatch_stage2], 0, [dnl
    table inet firewalld {
        chain filter_FWD_internal_dispatch_stage2 {
            oifname "foobar0" jump filter_FWD_internal_to_internal
            oifname "foobar1" jump filter_FWD_internal_to_internal
            oifname "net*" jump filter_FWD_internal_to_internal
            oifname "foobar2" jump filter_FWD_internal_to_public
            oifname "foobar3" jump filter_FWD_internal_to_public
            oifname "tun*" jump filter_FWD_internal_to_public
            jump filter_FWD_internal_to_public
        }
    }
])
NFT_LIST_RULES([inet], [filter_FWD_public_dispatch_stage2], 0, [dnl
    table inet firewalld {
        chain filter_FWD_public_dispatch_stage2 {
            oifname "foobar0" jump filter_FWD_public_to_internal
            oifname "foobar1" jump filter_FWD_public_to_internal
            oifname "net*" jump filter_FWD_public_to_internal
            oifname "foobar2" jump filter_FWD_public_to_public
            oifname "foobar3" jump filter_FWD_public_to_public
            oifname "tun*" jump filter_FWD_public_to_public
            jump filter_FWD_public_to_public
        }
    }
])

FWD_END_TEST
