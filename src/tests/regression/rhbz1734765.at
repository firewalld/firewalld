FWD_START_TEST([zone sources ordered by name])
AT_KEYWORDS(zone rhbz1734765 rhbz1421222 gh166 rhbz1738545)
dnl
dnl Users depend on firewalld ordering source-based zone dispatch by zone name.
dnl

SKIP_IF_FW_IN_CONTAINER_WITH_NFTABLES

FWD_CHECK([-q --permanent --new-zone=foobar_00])
FWD_CHECK([-q --permanent --new-zone=foobar_05])
FWD_CHECK([-q --permanent --new-zone=foobar_02])
FWD_CHECK([-q --permanent --new-zone=foobar_03])
FWD_CHECK([-q --permanent --new-zone=foobar_01])
FWD_CHECK([-q --permanent --new-zone=foobar_04])
FWD_CHECK([-q --permanent --new-zone=foobar_010])
FWD_CHECK([-q --permanent --new-zone=foobar_011])
FWD_CHECK([-q --permanent --new-zone=foobar_012])

FWD_CHECK([-q --permanent --new-ipset 'ipsetv4' --type hash:ip])
FWD_CHECK([-q --permanent --new-ipset 'ipsetv6' --type hash:ip --family=inet6])
FWD_CHECK([-q --permanent --ipset ipsetv4 --add-entry '192.0.2.12'])
FWD_CHECK([-q --permanent --ipset ipsetv6 --add-entry '::2'])

FWD_CHECK([-q --permanent --zone=foobar_011 --add-source ipset:ipsetv4])
FWD_CHECK([-q --permanent --zone=foobar_01 --add-source="10.1.1.0/24"])
FWD_CHECK([-q --permanent --zone=foobar_02 --add-source="10.1.0.0/16"])
FWD_CHECK([-q --permanent --zone=foobar_04 --add-source="10.2.0.0/16"])
FWD_CHECK([-q --permanent --zone=foobar_00 --add-source="10.1.1.1"])
FWD_CHECK([-q --permanent --zone=foobar_03 --add-source="10.2.2.0/24"])
FWD_CHECK([-q --permanent --zone=foobar_05 --add-source="10.0.0.0/8"])
IF_HOST_SUPPORTS_IPV6_RULES([
FWD_CHECK([-q --permanent --zone=foobar_01 --add-source="1234:5678::1:1:0/112"])
FWD_CHECK([-q --permanent --zone=foobar_02 --add-source="1234:5678::1:0:0/96"])
FWD_CHECK([-q --permanent --zone=foobar_04 --add-source="1234:5678::2:0:0/96"])
FWD_CHECK([-q --permanent --zone=foobar_03 --add-source="1234:5678::2:2:0/112"])
FWD_CHECK([-q --permanent --zone=foobar_05 --add-source="1234:5678::0:0:0/80"])
FWD_CHECK([-q --permanent --zone=foobar_00 --add-source="1234:5678::1:1:1"])
])

FWD_CHECK([-q --permanent --zone=internal --add-interface=foobar0])
FWD_CHECK([-q --permanent --zone=trusted --add-interface=foobar1])

FWD_RELOAD

NFT_LIST_SET([ipsetv4], 0, [dnl
    table inet firewalld {
        set ipsetv4 {
            type ipv4_addr
            flags interval
            elements = { 192.0.2.12 }
        }
    }
])
NFT_LIST_SET([ipsetv6], 0, [dnl
    table inet firewalld {
        set ipsetv6 {
            type ipv6_addr
            flags interval
            elements = { ::2 }
        }
    }
])

FWD_CHECK([-q --zone=foobar_010 --add-source="10.10.10.10"])
FWD_CHECK([-q --zone=public --add-source="20.20.20.20"])
IF_HOST_SUPPORTS_IPV6_RULES([
FWD_CHECK([-q --zone=foobar_010 --add-source="1234:5678::10:10:10"])
FWD_CHECK([-q --zone=public --add-source="1234:5678::20:20:20"])
FWD_CHECK([-q --zone=foobar_012 --add-source ipset:ipsetv6])
])
FWD_CHECK([-q --zone=foobar_010 --add-interface=foobar2])

NFT_LIST_RULES([inet], [filter_INPUT_dispatch], 0, [dnl
    table inet firewalld {
        chain filter_INPUT_dispatch {
            ip saddr 10.1.1.1 jump filter_IN_foobar_00_to_HOST
            ip6 saddr 1234:5678::1:1:1 jump filter_IN_foobar_00_to_HOST
            ip saddr 10.1.1.0/24 jump filter_IN_foobar_01_to_HOST
            ip6 saddr 1234:5678::1:1:0/112 jump filter_IN_foobar_01_to_HOST
            ip saddr 10.10.10.10 jump filter_IN_foobar_010_to_HOST
            ip6 saddr 1234:5678::10:10:10 jump filter_IN_foobar_010_to_HOST
            ip saddr @ipsetv4 jump filter_IN_foobar_011_to_HOST
            ip6 saddr @ipsetv6 jump filter_IN_foobar_012_to_HOST
            ip saddr 10.1.0.0/16 jump filter_IN_foobar_02_to_HOST
            ip6 saddr 1234:5678::1:0:0/96 jump filter_IN_foobar_02_to_HOST
            ip saddr 10.2.2.0/24 jump filter_IN_foobar_03_to_HOST
            ip6 saddr 1234:5678::2:2:0/112 jump filter_IN_foobar_03_to_HOST
            ip saddr 10.2.0.0/16 jump filter_IN_foobar_04_to_HOST
            ip6 saddr 1234:5678::2:0:0/96 jump filter_IN_foobar_04_to_HOST
            ip saddr 10.0.0.0/8 jump filter_IN_foobar_05_to_HOST
            ip6 saddr 1234:5678::/80 jump filter_IN_foobar_05_to_HOST
            ip6 saddr 1234:5678::20:20:20 jump filter_IN_public_to_HOST
            ip saddr 20.20.20.20 jump filter_IN_public_to_HOST
            iifname "foobar2" jump filter_IN_foobar_010_to_HOST
            iifname "foobar0" jump filter_IN_internal_to_HOST
            iifname "foobar1" jump filter_IN_trusted_to_HOST
            jump filter_IN_public_to_HOST
        }
    }
])
NFT_LIST_RULES([inet], [nat_POSTROUTING_dispatch], 0, [dnl
    table inet firewalld {
        chain nat_POSTROUTING_dispatch {
            ip saddr 10.1.1.1 jump nat_POST_foobar_00_dispatch_stage2
            ip6 saddr 1234:5678::1:1:1 jump nat_POST_foobar_00_dispatch_stage2
            ip saddr 10.1.1.0/24 jump nat_POST_foobar_01_dispatch_stage2
            ip6 saddr 1234:5678::1:1:0/112 jump nat_POST_foobar_01_dispatch_stage2
            ip saddr 10.10.10.10 jump nat_POST_foobar_010_dispatch_stage2
            ip6 saddr 1234:5678::10:10:10 jump nat_POST_foobar_010_dispatch_stage2
            ip saddr @ipsetv4 jump nat_POST_foobar_011_dispatch_stage2
            ip6 saddr @ipsetv6 jump nat_POST_foobar_012_dispatch_stage2
            ip saddr 10.1.0.0/16 jump nat_POST_foobar_02_dispatch_stage2
            ip6 saddr 1234:5678::1:0:0/96 jump nat_POST_foobar_02_dispatch_stage2
            ip saddr 10.2.2.0/24 jump nat_POST_foobar_03_dispatch_stage2
            ip6 saddr 1234:5678::2:2:0/112 jump nat_POST_foobar_03_dispatch_stage2
            ip saddr 10.2.0.0/16 jump nat_POST_foobar_04_dispatch_stage2
            ip6 saddr 1234:5678::2:0:0/96 jump nat_POST_foobar_04_dispatch_stage2
            ip saddr 10.0.0.0/8 jump nat_POST_foobar_05_dispatch_stage2
            ip6 saddr 1234:5678::/80 jump nat_POST_foobar_05_dispatch_stage2
            ip6 saddr 1234:5678::20:20:20 jump nat_POST_public_dispatch_stage2
            ip saddr 20.20.20.20 jump nat_POST_public_dispatch_stage2
            iifname "foobar2" jump nat_POST_foobar_010_dispatch_stage2
            iifname "foobar0" jump nat_POST_internal_dispatch_stage2
            iifname "foobar1" jump nat_POST_trusted_dispatch_stage2
            jump nat_POST_public_dispatch_stage2
        }
    }
])
NFT_LIST_RULES([inet], [nat_POST_foobar_00_dispatch_stage2], 0, [dnl
    table inet firewalld {
        chain nat_POST_foobar_00_dispatch_stage2 {
            ip daddr 10.1.1.1 jump nat_POST_foobar_00_to_foobar_00
            ip6 daddr 1234:5678::1:1:1 jump nat_POST_foobar_00_to_foobar_00
            ip daddr 10.1.1.0/24 jump nat_POST_foobar_00_to_foobar_01
            ip6 daddr 1234:5678::1:1:0/112 jump nat_POST_foobar_00_to_foobar_01
            ip daddr 10.10.10.10 jump nat_POST_foobar_00_to_foobar_010
            ip6 daddr 1234:5678::10:10:10 jump nat_POST_foobar_00_to_foobar_010
            ip daddr @ipsetv4 jump nat_POST_foobar_00_to_foobar_011
            ip6 daddr @ipsetv6 jump nat_POST_foobar_00_to_foobar_012
            ip daddr 10.1.0.0/16 jump nat_POST_foobar_00_to_foobar_02
            ip6 daddr 1234:5678::1:0:0/96 jump nat_POST_foobar_00_to_foobar_02
            ip daddr 10.2.2.0/24 jump nat_POST_foobar_00_to_foobar_03
            ip6 daddr 1234:5678::2:2:0/112 jump nat_POST_foobar_00_to_foobar_03
            ip daddr 10.2.0.0/16 jump nat_POST_foobar_00_to_foobar_04
            ip6 daddr 1234:5678::2:0:0/96 jump nat_POST_foobar_00_to_foobar_04
            ip daddr 10.0.0.0/8 jump nat_POST_foobar_00_to_foobar_05
            ip6 daddr 1234:5678::/80 jump nat_POST_foobar_00_to_foobar_05
            ip6 daddr 1234:5678::20:20:20 jump nat_POST_foobar_00_to_public
            ip daddr 20.20.20.20 jump nat_POST_foobar_00_to_public
            oifname "foobar2" jump nat_POST_foobar_00_to_foobar_010
            oifname "foobar0" jump nat_POST_foobar_00_to_internal
            oifname "foobar1" jump nat_POST_foobar_00_to_trusted
            jump nat_POST_foobar_00_to_public
        }
    }
])

