FWD_START_TEST([combined zones name length check])
AT_KEYWORDS(zone gh181)

AT_CHECK([mkdir -p ./zones/foobar])

AT_DATA([./zones/foobar/a_really_long_name_that_trigger_the_bug.xml], [dnl
<?xml version="1.0" encoding="utf-8"?>
<zone>
<short>foobar</short>
<description>foobar desc</description>
<service name="ssh"/>
</zone>
])

AT_DATA([./zones/foobar/another_really_long_name_that_trigger_the_bug_it_is_so_long_that_it_should_trigger_with_our_new_extendend_zone_and_policy_limits_blah_blah_blah_blah_blah_blah_blah_blah_blah_blah_blah_blah_blah.xml], [dnl
<?xml version="1.0" encoding="utf-8"?>
<zone>
<short>foobar</short>
<description>foobar desc</description>
<service name="http"/>
</zone>
])

FWD_RELOAD
FWD_CHECK([--zone=foobar --list-all | TRIM | grep ^services], 0, [dnl
services: http ssh
])
FWD_END_TEST
